_RUNNER="qemu-system-aarch64 -m 128 -cpu cortex-a53 -nographic -semihosting"
RUNNER_EL1="${_RUNNER} -machine virt -kernel"
RUNNER_EL2="${_RUNNER} -machine virt,virtualization=on -kernel"
RUNNER_EL2_NOKERNEL="${_RUNNER} -machine virt,virtualization=on"
RUNNER_EL3="${_RUNNER} -machine virt,secure=on -kernel"
RUNNER="${RUNNER_EL1}"
TARGET="aarch64-unknown-none"
